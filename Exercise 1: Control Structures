Scenario 1:
BEGIN
    FOR rec IN (SELECT CustomerID FROM Customers WHERE Age > 60)
    LOOP
        UPDATE Loans
        SET InterestRate = InterestRate - 1
        WHERE CustomerID = rec.CustomerID;
    END LOOP;

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Loan interest updated.');
END;
/


Scenario 2:
BEGIN
    FOR rec IN (SELECT CustomerID FROM Customers)
    LOOP
        UPDATE Customers
        SET IsVIP = 'TRUE'
        WHERE CustomerID = rec.CustomerID
        AND Balance > 10000;
    END LOOP;

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('VIP status updated.');
END;
/

